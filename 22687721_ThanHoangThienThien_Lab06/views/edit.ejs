<!DOCTYPE html>
<html>
<head>
<title>Sửa sản phẩm</title>

<link rel="stylesheet" href="/css/edit.css">

<!-- icon -->
<link rel="stylesheet"
href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

</head>

<body>

<header>
<h1><i class="fa-solid fa-pen-to-square"></i> Sửa sản phẩm</h1>
</header>

<div class="container">

<a href="/" class="btn-back">
<i class="fa-solid fa-arrow-left"></i> Quay lại danh sách
</a>

<div class="form-container">

<form action="/update/<%= product.ID %>" method="POST" enctype="multipart/form-data">

<div class="form-group">
<label for="ID">
<i class="fa-solid fa-barcode"></i> Mã sản phẩm
</label>

<input type="text" name="ID" id="ID"
value="<%= product.ID %>" readonly>
</div>


<div class="form-group">
<label for="name">
<i class="fa-solid fa-box"></i> Tên sản phẩm
</label>

<input type="text" name="name" id="name"
value="<%= product.name %>" required>
</div>


<div class="form-group">
<label for="price">
<i class="fa-solid fa-money-bill"></i> Giá (VNĐ)
</label>

<input type="number" name="price" id="price"
value="<%= product.price %>" required>
</div>


<div class="form-group">
<label for="quantity">
<i class="fa-solid fa-cubes"></i> Số lượng
</label>

<input type="number" name="quantity" id="quantity"
value="<%= product.quantity %>" required>
</div>


<div class="form-group">
<label>
<i class="fa-solid fa-image"></i> Hình ảnh hiện tại
</label>

<img id="currentImage"
src="<%= product.image %>"
alt="<%= product.name %>"
class="product-image-preview">
</div>


<div class="form-group">

<label for="imageInput">
<i class="fa-solid fa-upload"></i>
Chọn hình ảnh mới (nếu muốn thay đổi)
</label>

<input
type="file"
id="imageInput"
name="image"
accept="image/png, image/jpeg">

<p class="note">
<i class="fa-solid fa-circle-info"></i>
Chỉ chấp nhận JPG, JPEG, PNG. Tối đa 2MB
</p>

</div>


<div class="form-group">

<img id="preview"
src="#"
alt="Xem trước hình ảnh mới"
class="product-image-preview"
style="display:none">

</div>


<button type="submit" class="btn-submit">
<i class="fa-solid fa-floppy-disk"></i>
Cập nhật sản phẩm
</button>

</form>

</div>
</div>

<script>

const imageInput = document.getElementById("imageInput");
const preview = document.getElementById("preview");

imageInput.addEventListener("change", function () {

const file = this.files[0];

if(file){

preview.src = URL.createObjectURL(file);
preview.style.display = "block";

}else{

preview.style.display = "none";

}

});

</script>

</body>
</html>