<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="/css/dashboard.css">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<div class="dashboard">
  <!-- Sidebar -->
  <aside class="sidebar">
    <div class="sidebar-logo">
      <h3><i class="fas fa-box"></i> Product Admin</h3>
    </div>
    <nav class="sidebar-nav">
      <ul>
        <li><a href="/"><i class="fas fa-list"></i> Danh sách</a></li>
        <li><a href="/create" class="active"><i class="fas fa-plus"></i> Thêm mới</a></li>
      </ul>
    </nav>
  </aside>

  <main class="main">
    <header class="topbar">
      <div class="topbar-actions">
        <a href="/" class="btn btn-secondary">
          <i class="fas fa-arrow-left"></i> Quay lại danh sách
        </a>
      </div>
    </header>

    <div class="form-card">
      <h1 class="page-title mb-4">Sửa sản phẩm <small><%= product.name %></small></h1>
      
      <form method="POST" enctype="multipart/form-data">
        <div class="form-grid">
          <div class="form-group">
            <label class="form-label">ID</label>
            <input type="text" name="id" value="<%= product.id %>" class="form-control" readonly>
          </div>
          <div class="form-group">
            <label class="form-label">Tên sản phẩm <span class="text-danger">*</span></label>
            <input type="text" name="name" value="<%= product.name %>" class="form-control" required>
          </div>
        </div>
        
        <div class="form-grid">
          <div class="form-group">
            <label class="form-label">Giá (VNĐ) <span class="text-danger">*</span></label>
            <input type="number" name="price" value="<%= product.price %>" class="form-control" required min="0">
          </div>
          <div class="form-group">
            <label class="form-label">Tồn kho <span class="text-danger">*</span></label>
            <input type="number" name="unit_in_stock" value="<%= product.unit_in_stock %>" class="form-control" required min="0">
          </div>
        </div>
        
        <div class="form-group">
          <label class="form-label">Hình ảnh hiện tại</label>
          <img src="<%= product.url_image || '/images/default.png' %>" alt="<%= product.name %>" class="img-preview mb-3">
          <label class="form-label mt-3">Hình ảnh mới</label>
          <input type="file" name="image" class="form-control" accept="image/*">
        </div>
        
        <button type="submit" class="btn btn-primary btn-lg mt-4">
          <i class="fas fa-save"></i> Cập nhật sản phẩm
        </button>
      </form>
    </div>
  </main>
</div>