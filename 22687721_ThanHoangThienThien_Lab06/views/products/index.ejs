<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="/css/dashboard.css">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">


<div class="dashboard">
  <!-- Sidebar -->
  <aside class="sidebar">
    <div class="sidebar-logo">
      <h3><i class="fas fa-box"></i> Product Admin</h3>
    </div>
    <nav class="sidebar-nav">
      <ul>
        <li><a href="/" class="active"><i class="fas fa-list"></i> Danh sách</a></li>
        <li><a href="/create"><i class="fas fa-plus"></i> Thêm mới</a></li>
      </ul>
    </nav>
  </aside>

  <!-- Main -->
  <main class="main">
    <header class="topbar">
      <div class="topbar-search">
        <form method="GET">
          <i class="fas fa-search"></i>
          <input name="keyword" value="<%= keyword || '' %>" placeholder="Tìm kiếm..." class="form-control">
          <button type="submit">Tìm</button>
        </form>
      </div>
      <div class="topbar-actions">
        <a href="/create" class="btn btn-success">
          <i class="fas fa-plus"></i> Thêm sản phẩm
        </a>
      </div>
    </header>

    <div class="page-header">
      <h1 class="page-title">Danh sách sản phẩm</h1>
      <% if (query.msg) { %>
        <div class="alert alert-success"><%= query.msg %></div>
      <% } %>
    </div>

    <div class="table-container">
      <table class="table">
        <thead>
          <tr>
            <th>Hình ảnh</th>
            <th>Tên</th>
            <th>Giá</th>
            <th>Tồn kho</th>
            <th>Actions</th>
          </tr>
        </thead>
        <tbody>
          <% products.forEach(p => { %>
            <tr>
              <td>
                <img src="<%= p.url_image || '/images/default.png' %>" alt="<%= p.name %>" class="table-img">
              </td>
              <td><%= p.name %></td>
              <td class="fw-bold text-success">VND <%= Number(p.price).toLocaleString('vi-VN') %></td>
              <td>
                <% if (p.unit_in_stock < 5) { %>
                  <span class="badge badge-low">Thấp <%= p.unit_in_stock %></span>
                <% } else { %>
                  <span class="badge badge-high">Có <%= p.unit_in_stock %></span>
                <% } %>
              </td>
              <td>
<div class="btn-group">
                    <a href="/<%= p.id %>" class="btn btn-sm btn-info"><i class="fas fa-eye"></i></a>
                    <a href="/<%= p.id %>/edit" class="btn btn-sm btn-warning"><i class="fas fa-edit"></i></a>
                    <a href="/<%= p.id %>/delete" onclick="return confirm('Xóa <%= p.name %>?')" class="btn btn-sm btn-danger"><i class="fas fa-trash"></i></a>
                  </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <% if (typeof totalPages !== 'undefined' && totalPages > 1) { %>
      <div class="pagination">
        <% for(let i=1; i<=totalPages; i++) { %>
          <a href="?keyword=<%= typeof keyword !== 'undefined' ? keyword : '' %>&page=<%= i %>" class="btn btn-sm <%= i === currentPage ? 'btn-primary' : 'btn-outline-primary' %>"><%= i %></a>
        <% } %>
      </div>
    <% } %>
  </main>
</div>

<script>
document.querySelectorAll('.actions-dropdown button').forEach(btn => {
  btn.addEventListener('click', e => e.stopPropagation());
});
</script>