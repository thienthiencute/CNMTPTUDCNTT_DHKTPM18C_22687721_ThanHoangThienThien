<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
<link rel="stylesheet" href="/css/dashboard.css">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<div class="dashboard">
  <!-- Sidebar -->
  <aside class="sidebar">
    <div class="sidebar-logo">
      <h3><i class="fas fa-box"></i> Product Admin</h3>
    </div>
    <nav class="sidebar-nav">
      <ul>
        <li><a href="/"><i class="fas fa-list"></i> Danh sách</a></li>
        <li><a href="/create"><i class="fas fa-plus"></i> Thêm mới</a></li>
      </ul>
    </nav>
  </aside>

  <main class="main">
    <header class="topbar">
      <div class="topbar-actions">
        <a href="/" class="btn btn-secondary">
          <i class="fas fa-arrow-left"></i> Quay lại
        </a>
        <a href="/<%= product.id %>/edit" class="btn btn-primary">
          <i class="fas fa-edit"></i> Sửa
        </a>
      </div>
    </header>

    <div class="row">
      <div class="col-md-4">
        <div class="form-card text-center">
          <img src="<%= product.url_image || '/images/default.png' %>" alt="<%= product.name %>" class="img-preview mb-4">
          <h2><%= product.name %></h2>
        </div>
      </div>
      <div class="col-md-8">
        <div class="form-card">
          <h1 class="page-title mb-4">Chi tiết sản phẩm</h1>
          <div class="row">
            <div class="col-md-6">
              <label class="form-label fw-bold">ID:</label>
              <p class="form-control-plaintext"><%= product.id %></p>
            </div>
            <div class="col-md-6">
              <label class="form-label fw-bold">Giá:</label>
              <p class="form-control-plaintext fw-bold text-success">VND <%= Number(product.price).toLocaleString('vi-VN') %></p>
            </div>
          </div>
          <div class="row mt-3">
            <div class="col-md-6">
              <label class="form-label fw-bold">Tồn kho:</label>
              <span class="badge <%= product.unit_in_stock < 5 ? 'badge-low' : 'badge-high' %> fs-5">
                <%= product.unit_in_stock %>
              </span>
            </div>
            <div class="col-md-6">
              <label class="form-label fw-bold">Hình ảnh:</label>
              <p><%= product.url_image %></p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>
</div>