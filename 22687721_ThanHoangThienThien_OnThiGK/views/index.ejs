<link rel="stylesheet" href="/css/style.css">
<h2>🎟️ Quản lý vé Sự kiện</h2>

<form action="/" method="GET" style="margin-bottom: 20px;">
    <input name="search" placeholder="Tìm tên sự kiện/người mua...">
    <select name="status">
        <option value="">-- Trạng thái --</option>
        <option value="Upcoming">Upcoming</option>
        <option value="Sold">Sold</option>
    </select>
    <button type="submit">Tìm & Lọc</button>
    <a href="/add" class="btn btn-add">Thêm mới</a>
</form>

<table>
    <tr>
        <th>Ảnh</th><th>Sự kiện</th><th>Thành tiền</th><th>Thao tác</th>
    </tr>
    <% tickets.forEach(t => { %>
    <tr>
        <td><img src="<%= t.imageUrl %>" width="60"></td>
        <td><b><%= t.eventName %></b><br><small><%= t.holderName %></small></td>
        <td>
            <%= t.finalAmount.toLocaleString() %> VNĐ <br>
            <i style="color: green; font-size: 0.8em;"><%= t.discountNote %></i>
        </td>
        <td>
            <a href="/detail/<%= t.ticketId %>">Xem</a> | 
            <a href="/edit/<%= t.ticketId %>">Sửa</a> | 
            <a href="/delete/<%= t.ticketId %>" onclick="return confirm('Xóa?')">Xóa</a>
        </td>
    </tr>
    <% }) %>
</table>