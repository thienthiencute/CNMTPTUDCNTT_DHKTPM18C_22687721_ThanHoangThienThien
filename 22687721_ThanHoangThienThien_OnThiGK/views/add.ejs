<link rel="stylesheet" href="/css/style.css">
<h2>Thêm vé mới</h2>

<% if (errors && errors.length > 0) { %>
    <div class="error-box">
        <ul><% errors.forEach(err => { %> <li><%= err %></li> <% }) %></ul>
    </div>
<% } %>

<form action="/save" method="POST" enctype="multipart/form-data">
    Mã vé: <input name="ticketId" value="<%= ticket.ticketId || '' %>"><br><br>
    Sự kiện: <input name="eventName" value="<%= ticket.eventName || '' %>"><br><br>
    Người mua: <input name="holderName" value="<%= ticket.holderName || '' %>"><br><br>
    Loại vé: 
    <select name="category">
        <option value="Standard">Standard</option>
        <option value="VIP">VIP</option>
        <option value="VVIP">VVIP</option>
    </select><br><br>
    Số lượng: <input type="number" name="quantity" value="<%= ticket.quantity || 1 %>"><br><br>
    Giá: <input type="number" name="pricePerTicket" value="<%= ticket.pricePerTicket || '' %>"><br><br>
    Ngày: <input type="date" name="eventDate" value="<%= ticket.eventDate || '' %>"><br><br>
    Trạng thái: 
    <select name="status">
        <option value="Upcoming">Upcoming</option>
        <option value="Sold">Sold</option>
    </select><br><br>
    Ảnh minh họa: <input type="file" name="image"><br><br>
    <button type="submit" class="btn btn-add">Lưu vé</button>
    <a href="/">Quay lại</a>
</form>